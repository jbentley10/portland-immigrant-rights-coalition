# Server-side only (recommended - keeps tokens secure)
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_ACCESS_TOKEN=ACCESS_TOKEN_HERE
CONTENTFUL_SPACE_ID=SPACE_ID_HERE

# Legacy NEXT_PUBLIC_ vars (still supported for backwards compatibility)
# These expose tokens to the client bundle - use server-side vars above instead
# NEXT_PUBLIC_CONTENTFUL_ENVIRONMENT=master
# NEXT_PUBLIC_CONTENTFUL_ACCESS_TOKEN=ACCESS_TOKEN_HERE
# NEXT_PUBLIC_CONTENTFUL_SPACE_ID=SPACE_ID_HERE

# Secret for the Contentful webhook that triggers on-demand revalidation.
# Set this in Vercel env vars and in the Contentful webhook header (x-revalidate-secret).
CONTENTFUL_REVALIDATE_SECRET=YOUR_SECRET_HERE
